{
  "name": "ppt-skills",
  "version": "1.3.0",
  "description": "Open-source PPT generation skills with CJK-aware PptxGenJS workflows and AI image helpers.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CacinieP/ppt-skills.git"
  },
  "keywords": [
    "pptx",
    "pptxgenjs",
    "cjk",
    "presentation",
    "stepfun",
    "minimax",
    "ai-image"
  ],
  "scripts": {
    "color:qa": "node scripts/color-qa.mjs",
    "color:qa:presets": "node scripts/color-qa-presets.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "test": "node scripts/smoke-test.mjs && node scripts/color-qa-presets.mjs",
    "demo": "node examples/build_miku_demo.mjs",
    "qa:render": "echo 'qa:render requires LibreOffice: soffice --headless --convert-to pdf slides/output/presentation.pptx && pdftoppm -jpeg -r 100 presentation.pdf slide'"
  },
  "devDependencies": {
    "pptxgenjs": "^4.0.1"
  },
  "bugs": {
    "url": "https://github.com/CacinieP/ppt-skills/issues"
  },
  "homepage": "https://github.com/CacinieP/ppt-skills#readme",
  "license": "MIT"
}
